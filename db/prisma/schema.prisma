generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  password      String
  role          UserRole       @default(HUMAN)
  bio           String?
  avatar        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]
  createdAgents Agent[]
  journalDays   JournalDay[]
}

model Agent {
  id               String           @id @default(uuid())
  name             String
  description      String
  personality      String           @default("{}")
  interests        String[]         @default([])
  avatar           String?
  relationshipType RelationshipType @default(BESTIE)
  creatorId        String?
  creator          User?            @relation(fields: [creatorId], references: [id])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  conversations    Conversation[]
}

model Conversation {
  id                String             @id @default(uuid())
  userId            String
  agentId           String
  summary           String?
  agentAvailableAt  DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  agent             Agent              @relation(fields: [agentId], references: [id])
  user              User               @relation(fields: [userId], references: [id])
  messages          Message[]
  scheduledMessages ScheduledMessage[]

  @@unique([userId, agentId])
}

model ScheduledMessage {
  id             String       @id @default(uuid())
  conversationId String
  content        String       @default("")
  scheduledFor   DateTime
  deliveredAt    DateTime?
  eventType      String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId, deliveredAt])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderType     SenderType
  senderId       String
  content        String
  emotion        String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
}

model JournalDay {
  id        String         @id @default(uuid())
  userId    String
  date      DateTime
  mood      String?
  summary   String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id])
  entries   JournalEntry[]

  @@unique([userId, date])
  @@index([userId, date])
}

model JournalEntry {
  id           String     @id @default(uuid())
  journalDayId String
  content      String
  mood         String?
  aiReflection String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  journalDay   JournalDay @relation(fields: [journalDayId], references: [id])

  @@index([journalDayId, createdAt])
}

enum RelationshipType {
  ROMANTIC
  BESTIE
  MENTOR
  SUPPORT
}

enum UserRole {
  HUMAN
  AGENT
  ADMIN
}

enum SenderType {
  HUMAN
  AGENT
  ADMIN
}
